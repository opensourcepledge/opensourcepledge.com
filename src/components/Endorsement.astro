---
// © Vlad-Stefan Harbuz <vlad@vlad.website>
// SPDX-License-Identifier: Apache-2.0

interface Props {
  name: string;
  title?: string;
  handle: string;
  imageUrl: string;
  sourceUrl?: string;
  hidden?: boolean;
  extraClasses?: string;
}

const { name, title, handle, imageUrl, sourceUrl, hidden, extraClasses } = Astro.props;
---

<figure class={['endorsement', extraClasses].join(' ')} hidden={hidden}>
  <blockquote>
    <slot></slot>
  </blockquote>
  <figcaption>
    <img src={imageUrl} alt=`An image for ${name}`>
    <div>
      <div>{name}{title && <small> ({title})</small>}</div>
      {sourceUrl ? (
      <a href={sourceUrl} target="_blank"
        ><small>{handle}</small></a
      > ) : (
        <small>{handle}</small>
      )}
    </div>
  </figcaption>
</figure>

<style>
  .endorsement {
    position: relative;
    display: flex;
    justify-content: space-between;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
    blockquote {
      margin: 0;
    }
    figcaption {
      display: flex;
      align-items: center;
      gap: 1rem;
      line-height: 1.3;
      img {
        border-radius: 100%;
        width: 3rem;
        height: 3rem;
      }
    }
  }
</style>
