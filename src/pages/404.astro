import Blob from "../components/Blob.astro";
import Button from "../components/Button.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Not Found">
  <div class="edge-blobs">
    <Blob kind="solid-fill-03" top="75%" left="-10rem"></Blob>
  </div>
  <div class="container">
    <Blob kind="grad-dots-04" top="-2%" right="-20rem"></Blob>
    <Blob kind="solid-fill-05" top="20%" left="-16rem"></Blob>
    <Blob kind="solid-fill-04" top="90%" right="-20rem"></Blob>

    <main id="main-content">
      <section>
        <h1>We couldn't find this page…</h1>

        <p>
          …but we hope to find funding for the Open&nbsp;Source projects we all depend on.
        </p>

        <p>
          Are you ready to do your part?
        </p>
      </section>

      <section class="flex-center">
        <div>
          <div class="text-center">
            <Button href="/join"
              >Join the Pledge</Button
            >
          </div>
        </div>
      </section>
    </main>
  </div>
</Layout>

<style>
  h1 {
    font-size: var(--font-size-xxl);
    line-height: var(--line-height-xxl);
  }
  p {
    font-size: var(--font-size-xl);
    line-height: var(--line-height-xl);
    max-width: 35rem;
    text-align: left;
  }
</style>
