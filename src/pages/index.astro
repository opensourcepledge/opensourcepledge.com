  </main>
</Layout>

<style is:global>
  .member-logo-marquee {
    position: absolute;
    z-index: 100;
    bottom: 0;
    left: 0;
    right: 0;
  }
  @media (max-width: 900px) {
    .featured-endorsements .extra-endorsement {
      display: none;
    }
  }
  @media (max-width: 600px) {
    a.sentry-credit {
      justify-content: center;
    }
  }
</style>
<style>
  .hero-container {
    position: relative;
  }
  .hero-section {
    position: relative;
    margin-top: 3rem;
    .hero {
      display: flex;
      gap: 2rem;
      margin-bottom: 0.5rem;
      @media (max-width: 900px) {
        flex-direction: column;
      }
      h1 {
        margin: 0;
        font-size: 3.0rem;
        line-height: 1.05;
      }
      p {
        text-wrap: balance;
      }
      .hero-copy {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }
      .piggybank {
        position: relative;
        img {
          width: 50rem;
          max-width: 100%;
          position: relative;
          z-index: 95;
          border-top-left-radius: 6rem;
          border-top-right-radius: 1rem;
        }
      }
      .totals {
        display: flex;
        gap: 3rem;
        @media (max-width: 900px) {
          flex-direction: column;
          gap: 0.5rem;
          margin-bottom: 0;
        }
        strong {
          display: block;
          font-size: 1.8rem;
        }
      }
    }
  }
  .featured-endorsements {
    display: flex;
    gap: 3rem;
    padding-bottom: 1rem;
    @media (max-width: 900px) {
      flex-direction: column;
      blockquote:before {
        top: -1.4rem;
        left: -0.2rem;
      }
    }
    .endorsement {
      flex: 1;
      font-size: 0.9rem;
      figcaption {
        img {
          width: 2.3rem;
          height: 2.3rem;
        }
        a {
          display: none;
        }
      }
    }
  }
  .bottom-cta {
    h2 {
      font-size: 2.8rem;
      line-height: 1.2;
    }
  }
  .nasdaq-polaroid-section {
    .nasdaq-polaroid {
      position: relative;
      img {
        position: relative;
        z-index: 10;
        max-width: 100%;
        width: 25rem;
        aspect-ratio: 1 / 1;
        margin-bottom: 1rem;
        border-radius: 0.5rem;
        box-shadow: 0px 0px 50px 25px var(--color-bg);
        &:nth-child(2), &:nth-child(3) {
          position: absolute;
          top: 0;
          left: 0;
        }
        &:nth-child(2) {
          z-index: 5;
          transform: rotate(5deg);
        }
        &:nth-child(3) {
          top: 0;
          left: 0;
          z-index: 4;
          transform: rotate(10deg);
        }
      }
    }
    a {
      position: relative;
      z-index: 15;
    }
  }
  @media (max-width: 900px) {
    .hero-section {
      & > :global(.blob) {
        display: none;
      }
      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-right: 0;
      }
    }
    .bottom-cta {
      h2 {
        font-size: 2rem;
      }
    }
  }
</style>
