import {
  getMembers,
  getAllTimeTotalRaised,
  getLastYearTotalRaised,
  fmtCurrency,
} from '../members/common.ts';

const totalAlltime = getAllTimeTotalRaised(getMembers());
const totalArc = getLastYearTotalRaised(getMembers());
