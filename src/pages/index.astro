---
// © Functional Software, Inc. dba Sentry
// © Vlad-Stefan Harbuz <vlad@vlad.website>
// SPDX-License-Identifier: Apache-2.0

import ArticleList from "../components/ArticleList.astro";
import Blob from "../components/Blob.astro";
import Button from "../components/Button.astro";
import Endorsement from "../components/Endorsement.astro";
import Layout from "../layouts/Layout.astro";
import MemberLogoMarquee from "../components/MemberLogoMarquee.astro";
import TestimonialList from "../components/TestimonialList.astro";
import TextButton from "../components/TextButton.astro";

import {
  getMembers,
  getAllTimeTotalRaised,
  getLastYearTotalRaised,
  fmtCurrency,
} from '../members/common.ts';

const totalAlltime = getAllTimeTotalRaised(getMembers());
const totalArc = getLastYearTotalRaised(getMembers());
---

<Layout>
  <main id="main-content">
    <div class="hero-container">
      <div class="container">
        <Blob kind="solid-fill-01" top="55%" left="-20rem"></Blob>
        <Blob kind="solid-fill-05" top="70%" right="-16rem"></Blob>

        <section class="hero-section">
          <div class="hero">
            <div class="hero-copy">
              <div>
                <h1>Together,&nbsp;<br>we pay the<br>maintainers</h1>
                <p>Society depends on Open Source. We contribute cash to prevent maintainer burnout and supply chain risk.</p>
              </div>
              <div class="totals">
                <div>
                  <strong>{fmtCurrency(totalArc)}</strong>
                  past year, ${Math.floor(totalAlltime / 1000000)}M+ all time
                </div>
              </div>
              <div>
                <Button href="/about/">Learn More</Button>
              </div>
            </div>
            <div class="piggybank">
              <div
                class="custom-blob custom-blob--b custom-blob--under"
                style="top: -5%; right: -3.0rem"></div>
              <img src="https://vlad.website/t/test-harriet.webp" alt="TODO">
            </div>
          </div>
        </section>
      </div>
      <MemberLogoMarquee></MemberLogoMarquee>
    </div>

    <section>
      <div class="container">
        <div class="featured-endorsements">
          <Endorsement
            name="Open Source Initiative"
            handle="opensource.org/blog"
            imageUrl="/images/endorsers/osi.svg"
            sourceUrl="https://opensource.org/blog/the-open-source-initiative-supports-the-open-source-pledge"
          >
            <p
              >The OSI supports the Pledge. By taking the Pledge, companies [ensure] the
              long-term health of the Open Source projects they rely on.</p
            >
          </Endorsement>
          <Endorsement
            name="Accel"
            handle="accel.com/noteworthy"
            imageUrl="/images/endorsers/accel.svg"
            sourceUrl="https://www.accel.com/noteworthy/why-accel-is-supporting-the-open-source-pledge"
            extraClasses="extra-endorsement"
          >
            <p
              >The Open Source Pledge addresses a critical challenge facing the sustainability of the foundation upon
              which much of modern technology is built.</p
            >
          </Endorsement>
          <Endorsement
            name="Open Source Collective"
            handle="blog.opencollective.com"
            imageUrl="/images/endorsers/opensourcecollective.png"
            sourceUrl="https://blog.opencollective.com/why-the-open-source-pledge-is-both-relevant-and-timely/"
            extraClasses="extra-endorsement"
          >
            <p>The Open Source Pledge's simple message is incredibly important. Companies: pay your share.</p>
          </Endorsement>
        </div>

        <div class="section-bookend">
          <TextButton href="/endorsements/">All endorsements →</TextButton>
        </div>
      </div>
    </section>

    <section>
      <div class="container container--right">
        <Blob kind="solid-fill-05" top="20%" right="-16rem"></Blob>
        <div class="pictured-cta">
          <div class="picture picture--vlad-altctrlorg"></div>
          <div class="cta">
            <h2>Support the maintainers</h2>
            <p>Our member companies pay &gt;$2000/year/employed dev, directly to Open Source maintainers &amp; foundations.</p>
            <Button href="/join">Join now</Button>
          </div>
        </div>
      </div>
    </section>

    <section>
      <TestimonialList></TestimonialList>
    </section>

    <section>
      <div class="container">
        <Blob kind="solid-fill-04" top="-10%" left="-26rem"></Blob>
        <div class="section-bookend">
          <h2>Our thoughts on Open&nbsp;Source</h2>
        </div>
        <ArticleList count={5} compact={true}></ArticleList>
        <div class="section-bookend">
          <TextButton href="/blog/">See all posts →</TextButton>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .member-logo-marquee {
    position: absolute;
    z-index: 100;
    bottom: 0;
    left: 0;
    right: 0;
  }
  .testimonial-list {
    /* Visually compensate for ←/→ buttons */
    /* margin-top: -2.0rem; */
  }
  @media (max-width: 900px) {
    .featured-endorsements .extra-endorsement {
      display: none;
    }
  }
  @media (max-width: 600px) {
    a.sentry-credit {
      justify-content: center;
    }
  }
</style>
<style>
  .hero-container {
    position: relative;
  }
  .hero-container + section {
    margin-top: 2.5rem;
  }
  .hero-section {
    position: relative;
    margin-top: 3rem;
    margin-bottom: 0;
    .hero {
      display: flex;
      gap: 2rem;
      margin-bottom: 0.5rem;
      @media (max-width: 900px) {
        flex-direction: column;
      }
      h1 {
        margin: 0;
        font-size: 3.0rem;
        line-height: 1.05;
      }
      p {
        text-wrap: balance;
      }
      .hero-copy {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        p {
          text-align: left;
        }
      }
      .piggybank {
        position: relative;
        img {
          width: 50rem;
          max-width: 100%;
          position: relative;
          z-index: 95;
          border-top-left-radius: var(--border-radius-xl);
          border-top-right-radius: var(--border-radius-md);
        }
      }
      .totals {
        display: flex;
        gap: 3rem;
        @media (max-width: 900px) {
          flex-direction: column;
          gap: 0.5rem;
          margin-bottom: 0;
        }
        strong {
          display: block;
          font-size: 1.8rem;
        }
      }
    }
  }
  .featured-endorsements {
    display: flex;
    gap: 3rem;
    padding-bottom: 1rem;
    @media (max-width: 900px) {
      flex-direction: column;
    }
    .endorsement {
      flex: 1;
      font-size: 0.9rem;
      figcaption {
        img {
          width: 2.3rem;
          height: 2.3rem;
        }
        a {
          display: none;
        }
      }
    }
  }
  .bottom-cta {
    h2 {
      font-size: 2.8rem;
      line-height: 1.2;
    }
  }
  .nasdaq-polaroid-section {
    .nasdaq-polaroid {
      position: relative;
      img {
        position: relative;
        z-index: 10;
        max-width: 100%;
        width: 25rem;
        aspect-ratio: 1 / 1;
        margin-bottom: 1rem;
        border-radius: 0.5rem;
        box-shadow: 0px 0px 50px 25px var(--color-bg);
        &:nth-child(2), &:nth-child(3) {
          position: absolute;
          top: 0;
          left: 0;
        }
        &:nth-child(2) {
          z-index: 5;
          transform: rotate(5deg);
        }
        &:nth-child(3) {
          top: 0;
          left: 0;
          z-index: 4;
          transform: rotate(10deg);
        }
      }
    }
    a {
      position: relative;
      z-index: 15;
    }
  }
  @media (max-width: 900px) {
    .hero-section {
      & > :global(.blob) {
        display: none;
      }
      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-right: 0;
      }
    }
    .bottom-cta {
      h2 {
        font-size: 2rem;
      }
    }
  }
</style>
